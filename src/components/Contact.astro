---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const socialLinks = [
  {
    label: 'Email',
    href: 'mailto:sergioadgi38@gmail.com',
    display: 'sergioadgi38@gmail.com',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/sergio-arroni',
    display: 'linkedin.com/in/sergio-arroni',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'GitHub',
    href: 'https://github.com/SergioArroni',
    display: 'github.com/SergioArroni',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  },
  {
    label: 'ORCID',
    href: 'https://orcid.org/0000-0002-4907-8576',
    display: '0000-0002-4907-8576',
    icon: `<svg class="w-5 h-5" viewBox="0 0 256 256" fill="currentColor"><path d="M128 0C57.3 0 0 57.3 0 128s57.3 128 128 128 128-57.3 128-128S198.7 0 128 0zM86.3 186.2H70.9V79.1h15.4v107.1zm-7.7-121c-5.6 0-10.2-4.6-10.2-10.2s4.6-10.2 10.2-10.2 10.2 4.6 10.2 10.2-4.6 10.2-10.2 10.2zm105.5 121h-15.4V127c0-15.1-5.4-25.4-18.9-25.4-10.3 0-16.4 6.9-19.1 13.6-1 2.4-1.2 5.7-1.2 9.1v61.9h-15.4s.2-100.4 0-110.7h15.4v15.7c2-3.1 5.7-7.6 13.8-10.7 5.3-2 11.1-3.1 17.3-3.1 12.6 0 23.5 8.3 23.5 26.1v82.7z"/></svg>`,
  },
];
---

<section id="contact" class="relative py-24 md:py-32">
  <div class="section-container relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">
      <span class="gradient-text">{t.contact.title}</span>
    </h2>
    <p class="text-neural-muted text-center mb-12 max-w-md mx-auto">
      {t.contact.subtitle}
    </p>

    <div class="flex flex-col items-center gap-4 max-w-md mx-auto">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          target={link.label === 'Email' ? undefined : '_blank'}
          rel={link.label === 'Email' ? undefined : 'noopener noreferrer'}
          class="w-full glass-card px-6 py-4 border border-neural-nature/10 hover:border-neural-nature/30 transition-all duration-300 hover:glow-border group flex items-center gap-4"
        >
          <span class="text-neural-muted group-hover:text-neural-nature transition-colors shrink-0">
            <Fragment set:html={link.icon} />
          </span>
          <div>
            <p class="text-neural-muted text-xs uppercase tracking-wider">{link.label}</p>
            <p class="text-neural-text text-sm group-hover:text-neural-nature transition-colors">{link.display}</p>
          </div>
          <svg class="w-4 h-4 text-neural-muted/40 group-hover:text-neural-nature ml-auto transition-all group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="relative py-8 border-t border-neural-nature/10">
  <div class="section-container relative z-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-neural-muted/60">
      <p>© {new Date().getFullYear()} Sergio Arroni del Riego. {t.contact.rights}</p>
      <p class="flex items-center gap-1.5">
        {t.contact.footer_text}
        <svg class="w-4 h-4 text-neural-nature/40" viewBox="0 0 128 128" fill="currentColor">
          <path d="M81.7 14.8c-6.7-.1-11.4 3.7-14.3 8.4L64 29l-3.4-5.8C57.7 18.5 53 14.7 46.3 14.8c-8.5.2-15.5 7.2-15.3 15.7.1 4.3 1.9 8.1 4.7 10.9L64 72l28.3-30.6c2.8-2.8 4.6-6.6 4.7-10.9.2-8.5-6.8-15.5-15.3-15.7z"/>
          <path d="M119.4 51.6l-5.7-3.8L119.4 44c1.8-1.2 2.4-3.5 1.4-5.4l-3.2-5.6c-1-1.9-3.3-2.6-5.2-1.8l-6.4 2.7.6-6.9c.2-2.2-1.3-4.1-3.5-4.4l-6.5-.8c-2.2-.3-4.1 1.2-4.5 3.4l-1.3 6.8-5.1-4.6c-1.6-1.5-4.1-1.5-5.6.1l-4.6 4.8c-1.5 1.6-1.4 4.1.1 5.6l5.1 4.5-6.8 1.5c-2.1.5-3.5 2.5-3.2 4.7l.9 6.4c.3 2.2 2.3 3.6 4.4 3.4l6.9-.8-2.5 6.4c-.8 1.9-.1 4.2 1.8 5.1l5.7 3c1.9 1 4.2.2 5.3-1.6l3.6-5.8 3.6 5.8c1.1 1.8 3.3 2.6 5.3 1.6l5.7-3c1.9-1 2.5-3.2 1.8-5.1l-2.5-6.4 6.9.8c2.2.3 4.2-1.2 4.4-3.4l.9-6.4c.3-2.2-1.1-4.2-3.2-4.7l-6.8-1.5 5.1-4.5c1.6-1.5 1.7-4 .1-5.6l-4.6-4.8z"/>
        </svg>
      </p>
    </div>
  </div>
</footer>
