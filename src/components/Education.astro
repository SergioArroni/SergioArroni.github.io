---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const degreeIcons: Record<string, string> = {
  'Doctorado (PhD)': `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 14L3 9l9-5 9 5-9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M7 12v3.5C7 17.433 9.239 19 12 19s5-1.567 5-3.5V12"/></svg>`,
  'PhD': `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 14L3 9l9-5 9 5-9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M7 12v3.5C7 17.433 9.239 19 12 19s5-1.567 5-3.5V12"/></svg>`,
  'Máster': `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 5.5A2.5 2.5 0 017.5 3H19v15.5A2.5 2.5 0 0016.5 16H5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 5.5v15A2.5 2.5 0 007.5 23H19"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 7h6M9 10h6"/></svg>`,
  "Master's Degree": `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 5.5A2.5 2.5 0 017.5 3H19v15.5A2.5 2.5 0 0016.5 16H5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 5.5v15A2.5 2.5 0 007.5 23H19"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 7h6M9 10h6"/></svg>`,
  'Grado': `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 3l7 4-7 4-7-4 7-4z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 11l7 4 7-4"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 15l7 4 7-4"/></svg>`,
  "Bachelor's Degree": `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 3l7 4-7 4-7-4 7-4z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 11l7 4 7-4"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 15l7 4 7-4"/></svg>`,
};

const defaultDegreeIcon = `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5 4.462 5 2 6.462 2 8.267v7.466C2 17.538 4.462 19 7.5 19c1.746 0 3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c3.038 0 5.5 1.462 5.5 3.267v7.466C22 17.538 19.538 19 16.5 19c-1.746 0-3.332.477-4.5 1.253"/></svg>`;

const awardIconSvgs: Record<string, string> = {
  trophy: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3h14l-1.405 8.832A5 5 0 0112.63 16h-.26a5 5 0 01-4.965-4.168L6 3zM9 21h6M12 16v5M19 3c1 0 2 .5 2 2s-1 3-3 3M5 3c-1 0-2 .5-2 2s1 3 3 3"/></svg>`,
  star: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>`,
  medal: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="9" r="6" stroke-width="1.5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 15l-2 7 6-3 6 3-2-7"/></svg>`,
  award: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
};
---

<section id="education" class="relative py-24 md:py-32">
  <div class="section-container relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center">
      <span class="gradient-text">{t.education.title}</span>
    </h2>

    <!-- Vertical timeline -->
    <div class="relative max-w-3xl mx-auto">
      <!-- Timeline vine -->
      <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px">
        <svg class="w-1 h-full" preserveAspectRatio="none" viewBox="0 0 2 100">
          <path
            d="M1 0 Q0 10 1 20 Q2 30 1 40 Q0 50 1 60 Q2 70 1 80 Q0 90 1 100"
            stroke="url(#eduVineGradient)"
            stroke-width="2"
            fill="none"
            vector-effect="non-scaling-stroke"
          />
          <defs>
            <linearGradient id="eduVineGradient" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#818cf8" stop-opacity="0.6" />
              <stop offset="50%" stop-color="#14b8a6" stop-opacity="0.4" />
              <stop offset="100%" stop-color="#06b6d4" stop-opacity="0.2" />
            </linearGradient>
          </defs>
        </svg>
      </div>

      {t.education.degrees.map((degree, i) => (
        <div
          class="relative pl-12 md:pl-20 pb-14 last:pb-0 group opacity-0 translate-y-6"
          data-scroll-reveal
          data-delay={i * 150}
        >
          <!-- Timeline dot -->
          <div class="absolute left-2.5 md:left-6.5 top-1 w-3 h-3 rounded-full bg-neural-ai border-2 border-neural-bg shadow-[0_0_10px_rgba(129,140,248,0.4)] group-hover:shadow-[0_0_20px_rgba(129,140,248,0.6)] transition-shadow" />

          <!-- Degree card -->
          <div class="glass-card p-6 border border-neural-ai/10 hover:border-neural-ai/30 transition-all duration-300 hover:glow-border relative overflow-hidden">
            <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-neural-ai/5 to-transparent rounded-bl-full" />

            <div class="relative">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-3">
                  <div class="text-neural-ai shrink-0" set:html={degreeIcons[degree.degree] || defaultDegreeIcon} />
                  <div>
                    <h3 class="font-semibold text-neural-text text-lg group-hover:text-neural-ai transition-colors">
                      {degree.degree}
                    </h3>
                    <p class="text-neural-cyan text-sm font-medium">{degree.field}</p>
                  </div>
                </div>
                <span class="text-neural-muted/60 text-xs font-mono shrink-0 mt-1">{degree.period}</span>
              </div>

              {degree.url ? (
                <a href={degree.url} target="_blank" rel="noopener noreferrer" class="text-neural-muted text-sm mb-1 hover:text-neural-ai transition-colors inline-flex items-center gap-1">
                  {degree.institution}
                  <svg class="w-3 h-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              ) : (
                <p class="text-neural-muted text-sm mb-1">{degree.institution}</p>
              )}

              {degree.focus && (
                <p class="mt-2 text-xs text-neural-nature/80 bg-neural-nature/10 rounded-full px-3 py-1 inline-block">
                  {degree.focus}
                </p>
              )}

              {/* Awards associated to this degree */}
              {degree.awards && degree.awards.length > 0 && (
                <div class="mt-4 pt-4 border-t border-neural-ai/10">
                  <p class="text-xs font-mono uppercase tracking-wider text-neural-ai/50 mb-3">{t.awards.title}</p>
                  <div class="space-y-2">
                    {degree.awards.map((award) => (
                      <div class="flex items-start gap-2.5 group/award">
                        <span class="text-yellow-400 shrink-0 mt-0.5">
                          <Fragment set:html={awardIconSvgs[award.icon] || awardIconSvgs.trophy} />
                        </span>
                        <div>
                          <p class="text-neural-text text-sm font-medium group-hover/award:text-yellow-400 transition-colors">{award.title}</p>
                          <p class="text-neural-muted/70 text-xs">{award.description}</p>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Certifications -->
    <div class="mt-16">
      <h3 class="text-xl font-semibold text-neural-text mb-8 text-center opacity-0 translate-y-6" data-scroll-reveal data-delay="0">{t.education.certifications_title}</h3>
      <div class="flex flex-wrap justify-center gap-4 max-w-2xl mx-auto">
        {t.education.certifications.map((cert, i) => (
          <div class="glass-card px-5 py-3 border border-neural-teal/15 hover:border-neural-teal/40 transition-all flex items-center gap-3 group opacity-0 translate-y-6" data-scroll-reveal data-delay={i * 100}>
            <svg class="w-5 h-5 text-neural-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
            <div>
              <p class="text-neural-text text-sm font-medium group-hover:text-neural-teal transition-colors">{cert.name}</p>
              <p class="text-neural-muted text-xs">{cert.issuer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-neural-nature/20 to-transparent"></div>
</section>

<script>
  const eduObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || '0', 10);
          setTimeout(() => {
            el.style.transition = 'opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1)';
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          }, delay);
          eduObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -60px 0px' }
  );

  document.querySelectorAll('#education [data-scroll-reveal]').forEach((el) => {
    eduObserver.observe(el);
  });
</script>
