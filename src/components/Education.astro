---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const degreeIcons: Record<string, string> = {
  'Doctorado (PhD)': '🎓',
  'PhD': '🎓',
  'Máster': '📚',
  "Master's Degree": '📚',
  'Grado': '🎯',
  "Bachelor's Degree": '🎯',
};
---

<section id="education" class="relative py-24 md:py-32">
  <div class="section-container relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center">
      <span class="gradient-text">{t.education.title}</span>
    </h2>

    <!-- Degrees -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto mb-16">
      {t.education.degrees.map((degree, i) => (
        <div
          class="glass-card p-6 border border-neural-ai/10 hover:border-neural-ai/30 transition-all duration-300 hover:glow-border group relative overflow-hidden"
        >
          <!-- Background decoration -->
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-neural-ai/5 to-transparent rounded-bl-full" />

          <div class="relative">
            <span class="text-2xl mb-3 block">{degreeIcons[degree.degree] || '📖'}</span>
            <h3 class="font-semibold text-neural-text text-lg mb-1 group-hover:text-neural-ai transition-colors">
              {degree.degree}
            </h3>
            <p class="text-neural-cyan text-sm font-medium mb-2">{degree.field}</p>
            <p class="text-neural-muted text-sm mb-1">{degree.institution}</p>
            <p class="text-neural-muted/60 text-xs font-mono">{degree.period}</p>
            {degree.focus && (
              <p class="mt-3 text-xs text-neural-nature/80 bg-neural-nature/10 rounded-full px-3 py-1 inline-block">
                {degree.focus}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Certifications -->
    <h3 class="text-xl font-semibold text-neural-text mb-8 text-center">{t.education.certifications_title}</h3>
    <div class="flex flex-wrap justify-center gap-4 max-w-2xl mx-auto">
      {t.education.certifications.map((cert) => (
        <div class="glass-card px-5 py-3 border border-neural-teal/15 hover:border-neural-teal/40 transition-all flex items-center gap-3 group">
          <svg class="w-5 h-5 text-neural-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
          <div>
            <p class="text-neural-text text-sm font-medium group-hover:text-neural-teal transition-colors">{cert.name}</p>
            <p class="text-neural-muted text-xs">{cert.issuer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-neural-nature/20 to-transparent"></div>
</section>
