---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === 'es' ? 'en' : 'es';
const otherLangPath = lang === 'es' ? '/en/' : '/';

const navItems = [
  { label: t.nav.about, href: '#about' },
  { label: t.nav.skills, href: '#skills' },
  { label: t.nav.experience, href: '#experience' },
  { label: t.nav.education, href: '#education' },
  { label: t.nav.awards, href: '#awards' },
  { label: t.nav.publications, href: '#publications' },
  { label: t.nav.contact, href: '#contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={lang === 'es' ? '/' : '/en/'} class="font-bold text-xl text-neural-nature tracking-tight hover:text-neural-cyan transition-colors">
        SA<span class="text-neural-muted font-light">.</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center space-x-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="px-3 py-2 text-sm text-neural-muted hover:text-neural-nature transition-colors rounded-lg hover:bg-neural-nature/5"
          >
            {item.label}
          </a>
        ))}

        <!-- Language Toggle -->
        <a
          href={otherLangPath}
          class="ml-3 px-3 py-1.5 text-xs font-mono font-semibold border border-neural-nature/30 rounded-full text-neural-nature hover:bg-neural-nature/10 transition-all"
        >
          {otherLang.toUpperCase()}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-neural-muted hover:text-neural-nature transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="md:hidden hidden pb-4">
      <div class="flex flex-col space-y-1 glass-card p-4 mt-2">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="mobile-nav-link px-3 py-2 text-sm text-neural-muted hover:text-neural-nature transition-colors rounded-lg hover:bg-neural-nature/5"
          >
            {item.label}
          </a>
        ))}
        <a
          href={otherLangPath}
          class="px-3 py-2 text-sm font-mono font-semibold text-neural-nature"
        >
          {otherLang === 'en' ? '🇬🇧 English' : '🇪🇸 Español'}
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar')!;
  const mobileBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const menuIcon = document.getElementById('menu-icon')!;

  // Scroll effect
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > 50) {
      navbar.classList.add('bg-neural-bg/80', 'backdrop-blur-lg', 'border-b', 'border-neural-nature/10');
    } else {
      navbar.classList.remove('bg-neural-bg/80', 'backdrop-blur-lg', 'border-b', 'border-neural-nature/10');
    }
    lastScroll = currentScroll;
  });

  // Mobile menu toggle
  mobileBtn.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
    const isOpen = !mobileMenu.classList.contains('hidden');
    menuIcon.setAttribute('d', isOpen ? 'M6 18L18 6M6 6l12 12' : 'M4 6h16M4 12h16M4 18h16');
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    });
  });
</script>
