---
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";
import skillsData from "../data/skills.json";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="skills" class="relative py-24 md:py-32">
  <div class="section-container relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">
      <span class="gradient-text">{t.skills.title}</span>
    </h2>
    <p class="text-neural-muted text-center mb-8 max-w-xl mx-auto text-sm">
      {t.skills.subtitle}
    </p>

    <!-- Side labels -->
    <div class="flex justify-between max-w-5xl mx-auto mb-2 px-4">
      <span
        class="text-xs font-mono uppercase tracking-widest text-neural-nature/50"
        >AI & Research</span
      >
      <span
        class="text-xs font-mono uppercase tracking-widest text-neural-cyan/50"
        >Engineering</span
      >
    </div>

    <div
      id="skill-graph-container"
      class="w-full max-w-5xl mx-auto relative"
      style="min-height: 550px;"
    >
      <svg id="skill-graph" class="w-full" style="min-height: 550px;"></svg>
    </div>
    <script
      id="skill-graph-data"
      type="application/json"
      set:html={JSON.stringify({
        categories: skillsData.categories,
        connections: skillsData.connections,
        lang,
      })}
    />
  </div>

  <div
    class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-neural-nature/20 to-transparent"
  >
  </div>
</section>

<script>
  (async function () {
    // Wait for full page load so CSS layout is computed and container has real width
    if (document.readyState !== "complete") {
      await new Promise<void>((r) =>
        window.addEventListener("load", () => r(), { once: true }),
      );
    }

    const d3 = await import("d3");

    const dataEl = document.getElementById("skill-graph-data");
    if (!dataEl || !dataEl.textContent) return;
    const payload = JSON.parse(dataEl.textContent);
    const data = {
      categories: payload.categories,
      connections: payload.connections,
    };
    const lang = payload.lang || "es";

    function getLabel(label: any): string {
      if (typeof label === "string") return label;
      return label[lang] || label["es"] || "";
    }

    const container = document.getElementById("skill-graph-container");
    if (!container) return;
    const svg = d3.select("#skill-graph");
    svg.selectAll("*").remove();

    let width = container.clientWidth || container.offsetWidth || 900;
    let height = Math.max(550, Math.min(750, window.innerHeight * 0.65));

    svg
      .attr("viewBox", `0 0 ${width} ${height}`)
      .attr("width", width)
      .attr("height", height);

    interface GraphNode {
      id: string;
      label: string;
      color: string;
      radius: number;
      isCategory: boolean;
      parentId?: string;
      side: "ai" | "eng";
      visible: boolean;
      hasChildren: boolean;
      x: number;
      y: number;
    }

    interface GraphLink {
      source: string;
      target: string;
      isParentChild: boolean;
    }

    const nodes: GraphNode[] = [];
    const links: GraphLink[] = [];
    const expandedCategories = new Set<string>();

    const aiCategories: string[] = [];
    const engCategories: string[] = [];

    data.categories.forEach((cat: any) => {
      const side = cat.side === "eng" ? "eng" : "ai";
      if (side === "ai") aiCategories.push(cat.id);
      else engCategories.push(cat.id);

      const hasChildren = cat.children && cat.children.length > 0;
      nodes.push({
        id: cat.id,
        label: getLabel(cat.label),
        color: cat.color,
        radius: 35,
        isCategory: true,
        side,
        visible: true,
        hasChildren,
        x: 0,
        y: 0,
      });

      if (cat.children) {
        cat.children.forEach((child: any) => {
          nodes.push({
            id: child.id,
            label: getLabel(child.label),
            color: cat.color,
            radius: 18,
            isCategory: false,
            parentId: cat.id,
            side,
            visible: false,
            hasChildren: false,
            x: 0,
            y: 0,
          });
          links.push({
            source: cat.id,
            target: child.id,
            isParentChild: true,
          });
        });
      }
    });

    data.connections.forEach((conn: [string, string]) => {
      links.push({ source: conn[0], target: conn[1], isParentChild: false });
    });

    // --- Hexagonal layout ---
    function hexagonPositions(
      count: number,
      cx: number,
      cy: number,
      r: number,
    ): [number, number][] {
      const pts: [number, number][] = [];
      for (let i = 0; i < count; i++) {
        const angle = -Math.PI / 2 + (i / count) * Math.PI * 2;
        pts.push([cx + Math.cos(angle) * r, cy + Math.sin(angle) * r]);
      }
      return pts;
    }

    function assignNodePositions() {
      const cy = height / 2;
      const lx = width * 0.27;
      const rx = width * 0.73;
      const rAi = Math.min(width * 0.2, height * 0.32);
      const rEng = Math.min(width * 0.2, height * 0.32);

      const aiPos = hexagonPositions(aiCategories.length, lx, cy, rAi);
      aiCategories.forEach((catId, i) => {
        const node = nodes.find((n) => n.id === catId);
        if (!node) return;
        node.x = aiPos[i][0];
        node.y = aiPos[i][1];
        placeChildren(node, Math.atan2(node.y - cy, node.x - lx));
      });

      const engPos = hexagonPositions(engCategories.length, rx, cy, rEng);
      engCategories.forEach((catId, i) => {
        const node = nodes.find((n) => n.id === catId);
        if (!node) return;
        node.x = engPos[i][0];
        node.y = engPos[i][1];
        placeChildren(node, Math.atan2(node.y - cy, node.x - rx));
      });
    }

    function placeChildren(parent: GraphNode, outAngle: number) {
      const children = nodes.filter(
        (n) => n.parentId === parent.id && n.visible,
      );
      if (!children.length) return;
      const spread = Math.PI * 0.6;
      const childR = 75;
      children.forEach((child, i) => {
        const a =
          outAngle - spread / 2 + ((i + 1) / (children.length + 1)) * spread;
        child.x = parent.x + Math.cos(a) * childR;
        child.y = parent.y + Math.sin(a) * childR;
      });
    }

    assignNodePositions();

    // --- SVG defs ---
    const defs = svg.append("defs");
    const filter = defs.append("filter").attr("id", "glow");
    filter
      .append("feGaussianBlur")
      .attr("stdDeviation", "4")
      .attr("result", "coloredBlur");
    const feMerge = filter.append("feMerge");
    feMerge.append("feMergeNode").attr("in", "coloredBlur");
    feMerge.append("feMergeNode").attr("in", "SourceGraphic");

    // Hexagon outlines
    function hexPath(cx: number, cy: number, r: number, count: number): string {
      const pts = hexagonPositions(count, cx, cy, r);
      return (
        pts.map((p, i) => `${i === 0 ? "M" : "L"}${p[0]},${p[1]}`).join(" ") +
        " Z"
      );
    }

    svg
      .append("path")
      .attr(
        "d",
        hexPath(
          width * 0.27,
          height / 2,
          Math.min(width * 0.2, height * 0.32) + 15,
          aiCategories.length,
        ),
      )
      .attr("fill", "none")
      .attr("stroke", "#22c55e")
      .attr("stroke-opacity", 0.06)
      .attr("stroke-width", 1)
      .attr("stroke-dasharray", "4,6");

    svg
      .append("path")
      .attr(
        "d",
        hexPath(
          width * 0.73,
          height / 2,
          Math.min(width * 0.2, height * 0.32) + 15,
          engCategories.length,
        ),
      )
      .attr("fill", "none")
      .attr("stroke", "#06b6d4")
      .attr("stroke-opacity", 0.06)
      .attr("stroke-width", 1)
      .attr("stroke-dasharray", "4,6");

    // Divider
    svg
      .append("line")
      .attr("x1", width / 2)
      .attr("y1", 20)
      .attr("x2", width / 2)
      .attr("y2", height - 20)
      .attr("stroke", "#22c55e")
      .attr("stroke-opacity", 0.08)
      .attr("stroke-width", 1)
      .attr("stroke-dasharray", "6,8")
      .attr("class", "divider");

    const linkGroup = svg.append("g").attr("class", "links");
    const nodeGroup = svg.append("g").attr("class", "nodes");

    function getVisibleNodes() {
      return nodes.filter((n) => n.visible);
    }
    function getVisibleLinks() {
      const ids = new Set(getVisibleNodes().map((n) => n.id));
      return links.filter((l) => ids.has(l.source) && ids.has(l.target));
    }
    function nodeById(id: string) {
      return nodes.find((n) => n.id === id);
    }

    function toggleCategory(catId: string) {
      if (expandedCategories.has(catId)) {
        expandedCategories.delete(catId);
        nodes.forEach((n) => {
          if (n.parentId === catId) n.visible = false;
        });
      } else {
        expandedCategories.add(catId);
        nodes.forEach((n) => {
          if (n.parentId === catId) n.visible = true;
        });
      }
      render();
    }

    function render() {
      assignNodePositions();
      const visibleNodes = getVisibleNodes();
      const visibleLinks = getVisibleLinks();

      // Links
      const linkSel = linkGroup
        .selectAll<SVGLineElement, GraphLink>("line")
        .data(visibleLinks, (d: any) => `${d.source}-${d.target}`);
      linkSel
        .exit()
        .transition("exit")
        .duration(300)
        .attr("opacity", 0)
        .remove();
      const linkEnter = linkSel
        .enter()
        .append("line")
        .attr("stroke", (d) => nodeById(d.source)?.color ?? "#22c55e")
        .attr("stroke-opacity", 0)
        .attr("stroke-width", (d) => (d.isParentChild ? 1 : 1.5))
        .attr("stroke-dasharray", (d) => (d.isParentChild ? "4,4" : "none"))
        .attr("x1", (d) => nodeById(d.source)?.x ?? 0)
        .attr("y1", (d) => nodeById(d.source)?.y ?? 0)
        .attr("x2", (d) => nodeById(d.target)?.x ?? 0)
        .attr("y2", (d) => nodeById(d.target)?.y ?? 0);
      linkEnter
        .transition("enter")
        .duration(500)
        .attr("stroke-opacity", (d) => (d.isParentChild ? 0.3 : 0.15));

      linkEnter
        .merge(linkSel)
        .transition("position")
        .duration(400)
        .attr("x1", (d: any) => nodeById(d.source)?.x ?? 0)
        .attr("y1", (d: any) => nodeById(d.source)?.y ?? 0)
        .attr("x2", (d: any) => nodeById(d.target)?.x ?? 0)
        .attr("y2", (d: any) => nodeById(d.target)?.y ?? 0);

      // Nodes
      const nodeSel = nodeGroup
        .selectAll<SVGGElement, GraphNode>("g.node")
        .data(visibleNodes, (d: GraphNode) => d.id);
      nodeSel
        .exit()
        .transition("exit")
        .duration(300)
        .attr("opacity", 0)
        .remove();

      const ne = nodeSel
        .enter()
        .append("g")
        .attr("class", "node")
        .attr("opacity", 0)
        .attr("transform", (d) => `translate(${d.x},${d.y})`)
        .style("cursor", (d) =>
          d.isCategory && d.hasChildren ? "pointer" : "default",
        );

      ne.append("circle")
        .attr("r", (d) => d.radius)
        .attr("fill", (d) => `${d.color}15`)
        .attr("stroke", (d) => d.color)
        .attr("stroke-width", (d) => (d.isCategory ? 2 : 1))
        .attr("stroke-opacity", (d) => (d.isCategory ? 0.6 : 0.4))
        .attr("filter", (d) => (d.isCategory ? "url(#glow)" : "none"));

      ne.append("text")
        .attr("class", "node-label")
        .attr("text-anchor", "middle")
        .attr("dy", "0.35em")
        .attr("fill", (d) => (d.isCategory ? d.color : "#e2e8f0"))
        .attr("font-size", (d) => (d.isCategory ? "11px" : "9px"))
        .attr("font-weight", (d) => (d.isCategory ? "600" : "400"))
        .attr("font-family", "Inter, system-ui, sans-serif")
        .attr("pointer-events", "none")
        .each(function (d) {
          const t = d3.select(this);
          const w = d.label.split(/\s+/);
          if (w.length > 1 && d.isCategory) {
            t.text("");
            w.forEach((word: string, i: number) => {
              t.append("tspan")
                .attr("x", 0)
                .attr("dy", i === 0 ? `-${(w.length - 1) * 0.3}em` : "1.1em")
                .text(word);
            });
          } else {
            t.text(d.label);
          }
        });

      ne.filter((d) => d.isCategory && d.hasChildren)
        .append("text")
        .attr("class", "expand-indicator")
        .attr("text-anchor", "middle")
        .attr("dy", (d) => {
          const w = d.label.split(/\s+/);
          return w.length > 1 ? `${w.length * 0.5 + 0.8}em` : "1.8em";
        })
        .attr("fill", (d) => d.color)
        .attr("font-size", "8px")
        .attr("opacity", 0.5);

      ne.transition("enter").duration(500).attr("opacity", 1);

      // Update expand indicators on active nodes
      const allN = ne.merge(nodeSel);
      allN
        .select(".expand-indicator")
        .text((d: any) =>
          d.isCategory && d.hasChildren
            ? expandedCategories.has(d.id)
              ? "−"
              : "+"
            : "",
        );

      // Interactions
      allN
        .on("mouseenter", function (_e: any, d: GraphNode) {
          d3.select(this)
            .select("circle")
            .transition()
            .duration(200)
            .attr("stroke-opacity", 1)
            .attr("stroke-width", 3);
          allN
            .filter((n: GraphNode) => n.id !== d.id)
            .transition()
            .duration(200)
            .attr("opacity", (n: GraphNode) =>
              visibleLinks.some(
                (l) =>
                  (l.source === d.id && l.target === n.id) ||
                  (l.target === d.id && l.source === n.id),
              )
                ? 0.9
                : 0.2,
            );
          linkGroup
            .selectAll<SVGLineElement, GraphLink>("line")
            .transition()
            .duration(200)
            .attr("stroke-opacity", (l: any) =>
              l.source === d.id || l.target === d.id ? 0.6 : 0.03,
            );
        })
        .on("mouseleave", function () {
          allN.transition().duration(200).attr("opacity", 1);
          allN
            .selectAll("circle")
            .transition()
            .duration(200)
            .attr("stroke-opacity", (d: any) => (d.isCategory ? 0.6 : 0.4))
            .attr("stroke-width", (d: any) => (d.isCategory ? 2 : 1));
          linkGroup
            .selectAll<SVGLineElement, GraphLink>("line")
            .transition()
            .duration(200)
            .attr("stroke-opacity", (d: any) => (d.isParentChild ? 0.3 : 0.15));
        })
        .on("click", null);

      allN
        .filter((d: GraphNode) => d.isCategory && d.hasChildren)
        .on("click", function (ev: any, d: GraphNode) {
          ev.stopPropagation();
          toggleCategory(d.id);
        });

      allN
        .transition("position")
        .duration(450)
        .attr("transform", (d) => `translate(${d.x},${d.y})`);
    }

    render();

    // Resize
    let rt: number;
    window.addEventListener("resize", () => {
      clearTimeout(rt);
      rt = window.setTimeout(() => {
        width = container!.clientWidth || 900;
        height = Math.max(550, Math.min(750, window.innerHeight * 0.65));
        svg
          .attr("viewBox", `0 0 ${width} ${height}`)
          .attr("width", width)
          .attr("height", height);
        svg.selectAll("path[d]").remove();
        svg
          .insert("path", ".links")
          .attr(
            "d",
            hexPath(
              width * 0.27,
              height / 2,
              Math.min(width * 0.2, height * 0.32) + 15,
              aiCategories.length,
            ),
          )
          .attr("fill", "none")
          .attr("stroke", "#22c55e")
          .attr("stroke-opacity", 0.06)
          .attr("stroke-width", 1)
          .attr("stroke-dasharray", "4,6");
        svg
          .insert("path", ".links")
          .attr(
            "d",
            hexPath(
              width * 0.73,
              height / 2,
              Math.min(width * 0.2, height * 0.32) + 15,
              engCategories.length,
            ),
          )
          .attr("fill", "none")
          .attr("stroke", "#06b6d4")
          .attr("stroke-opacity", 0.06)
          .attr("stroke-width", 1)
          .attr("stroke-dasharray", "4,6");
        render();
      }, 250);
    });
  })();
</script>
