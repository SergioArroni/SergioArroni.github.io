---

<section id="contact" class="relative py-24 md:py-32">
  <div class="section-container relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">
      <span class="gradient-text">{t.contact.title}</span>
    </h2>
    <p class="text-neural-muted text-center mb-12 max-w-md mx-auto">
      {t.contact.subtitle}
    </p>

    <div class="flex flex-col items-center gap-4 max-w-md mx-auto">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            target={link.label === "Email" ? undefined : "_blank"}
            rel={link.label === "Email" ? undefined : "noopener noreferrer"}
            class="w-full glass-card px-6 py-4 border border-neural-nature/10 hover:border-neural-nature/30 transition-all duration-300 hover:glow-border group flex items-center gap-4"
          >
            <span class="text-neural-muted group-hover:text-neural-nature transition-colors shrink-0">
              <Fragment set:html={link.icon} />
            </span>
            <div>
              <p class="text-neural-muted text-xs uppercase tracking-wider">
                {link.label}
              </p>
              <p class="text-neural-text text-sm group-hover:text-neural-nature transition-colors">
                {link.display}
              </p>
            </div>
            <svg
              class="w-4 h-4 text-neural-muted/40 group-hover:text-neural-nature ml-auto transition-all group-hover:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="relative py-8 border-t border-neural-nature/10">
  <div class="section-container relative z-10">
    <div
      class="flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-neural-muted/60"
    >
      <p>
        © {new Date().getFullYear()} Sergio Arroni del Riego. {t.contact.rights}
      </p>
      <p class="flex items-center gap-1.5">
        {t.contact.footer_text}
        <svg
          class="w-4 h-4 text-neural-nature/40"
          viewBox="0 0 128 128"
          fill="currentColor"
        >
          <path
            d="M81.7 14.8c-6.7-.1-11.4 3.7-14.3 8.4L64 29l-3.4-5.8C57.7 18.5 53 14.7 46.3 14.8c-8.5.2-15.5 7.2-15.3 15.7.1 4.3 1.9 8.1 4.7 10.9L64 72l28.3-30.6c2.8-2.8 4.6-6.6 4.7-10.9.2-8.5-6.8-15.5-15.3-15.7z"
          ></path>
