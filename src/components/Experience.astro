---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="experience" class="relative py-24 md:py-32">
  <div class="section-container relative z-10">
    <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center">
      <span class="gradient-text">{t.experience.title}</span>
    </h2>

    <div class="relative max-w-3xl mx-auto">
      <!-- Organic vine line -->
      <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px">
        <svg class="w-1 h-full" preserveAspectRatio="none" viewBox="0 0 2 100">
          <path
            d="M1 0 Q0 10 1 20 Q2 30 1 40 Q0 50 1 60 Q2 70 1 80 Q0 90 1 100"
            stroke="url(#vineGradient)"
            stroke-width="2"
            fill="none"
            vector-effect="non-scaling-stroke"
          />
          <defs>
            <linearGradient id="vineGradient" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#22c55e" stop-opacity="0.6" />
              <stop offset="50%" stop-color="#14b8a6" stop-opacity="0.4" />
              <stop offset="100%" stop-color="#06b6d4" stop-opacity="0.2" />
            </linearGradient>
          </defs>
        </svg>
      </div>

      {t.experience.roles.map((role, index) => (
        <div
          class="relative pl-12 md:pl-20 pb-16 last:pb-0 group opacity-0 translate-y-6"
          data-scroll-reveal
          data-delay={index * 120}
        >
          <!-- Timeline dot -->
          <div class="absolute left-2.5 md:left-6.5 top-1 w-3 h-3 rounded-full bg-neural-nature border-2 border-neural-bg shadow-[0_0_10px_rgba(34,197,94,0.4)] group-hover:shadow-[0_0_20px_rgba(34,197,94,0.6)] transition-shadow" />

          <!-- Card -->
          <div class="glass-card p-6 border border-neural-nature/10 hover:border-neural-nature/25 transition-all duration-300 hover:glow-border">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-3">
              <div>
                <h3 class="text-lg font-semibold text-neural-text group-hover:text-neural-nature transition-colors">
                  {role.role}
                </h3>
                <p class="text-neural-cyan text-sm font-medium">{role.company}</p>
              </div>
              <span class="text-neural-muted text-xs font-mono mt-1 sm:mt-0 shrink-0">{role.period}</span>
            </div>

            <p class="text-neural-muted text-sm mb-4 leading-relaxed">{role.description}</p>

            <ul class="space-y-1.5 mb-4">
              {role.highlights.map((highlight) => (
                <li class="text-neural-muted/80 text-sm flex items-start gap-2">
                  <span class="text-neural-nature mt-1 shrink-0">›</span>
                  <span>{highlight}</span>
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-2">
              {role.tags.map((tag) => (
                <span class="px-2.5 py-0.5 text-xs font-mono bg-neural-nature/10 text-neural-nature/80 rounded-full border border-neural-nature/15">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-neural-nature/20 to-transparent"></div>
</section>

<script>
  const expObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseInt(el.dataset.delay || '0', 10);
          setTimeout(() => {
            el.style.transition = 'opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1)';
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          }, delay);
          expObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -60px 0px' }
  );

  document.querySelectorAll('#experience [data-scroll-reveal]').forEach((el) => {
    expObserver.observe(el);
  });
</script>
